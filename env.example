# Supabase — Project Settings → API
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Groq API (free, no credit card) — https://console.groq.com
# Note: llama-3.3-70b-versatile / llama-3.1-8b-instant are being retired by
# Groq on 08/16/26 — using their recommended replacements instead.
GROQ_API_KEY=
GROQ_MODEL_PRIMARY=openai/gpt-oss-120b
GROQ_MODEL_FALLBACK=openai/gpt-oss-20b

# Twilio — https://twilio.com (SMS, click-to-call, WhatsApp)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WHATSAPP_NUMBER=

# Dodo Payments — https://dodopayments.com
DODO_PAYMENTS_API_KEY=
DODO_PAYMENTS_WEBHOOK_KEY=
DODO_PAYMENTS_ENVIRONMENT=test_mode
DODO_PRODUCT_STANDARD=
DODO_PRODUCT_MULTILOCATION=

# Your deployed site URL (no trailing slash) — used for Dodo return_url and
# for verifying the Twilio SMS webhook signature
SITE_URL=http://localhost:3000

# Optional — IANA timezone used for the 9pm-8am no-SMS quiet hours window.
# Defaults to America/New_York if not set.
QUIET_HOURS_TZ=America/New_York
